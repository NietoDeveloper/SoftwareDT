#####################################################################
#           CONFIGURACIÓN DEPLOY - SOFTWARE DT (EJEMPLO)            #
#####################################################################

# 🛰️ SOFTWARE DT CORE - ENVIRONMENT CONFIG
# Usa 'production' cuando vayas a desplegar en Railway o AWS
NODE_ENV=development
PORT=8080

# --- FRONTEND SYNC ---
# URLs de tu frontend (pueden ser localhost en desarrollo)
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://tusitio.vercel.app

# --- DATACENTERS ATLAS ---
# Reemplaza <user>, <password> y <cluster> con tus credenciales reales de MongoDB Atlas
MONGODB_URI_USUARIOS=mongodb+srv://<USUARIO>:<PASSWORD>@<CLUSTER>.mongodb.net/nombre_db?retryWrites=true&w=majority
MONGODB_URI_CITAS=mongodb+srv://<USUARIO>:<PASSWORD>@<CLUSTER>.mongodb.net/nombre_db_citas?retryWrites=true&w=majority

# --- SECURITY (Nivel S+) ---
# Genera strings aleatorios largos y complejos de 64 caracteres para producción
ACCESS_TOKEN_SECRET=tu_secreto_para_el_access_token_super_seguro_y_largo
REFRESH_TOKEN_SECRET=tu_secreto_para_el_refresh_token_super_seguro_y_largo

# --- ADMIN SEED ---
ADMIN_EMAIL=tu_correo_admin@dominio.com
ADMIN_NAME="Nombre del Administrador"