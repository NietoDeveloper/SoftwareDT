# === STAGE 1: Build ===
FROM node:20-alpine AS builder

WORKDIR /app

# Copiar archivos de dependencias para aprovechar el caché de Docker
COPY package*.json ./

# Instalar dependencias
RUN npm install

# Copiar el resto del código
COPY . .

# Construir la aplicación (Vite/Next.js compilará a la carpeta 'dist' o 'out')
RUN npm run build

# === STAGE 2: Production ===
FROM nginx:alpine AS runner

WORKDIR /usr/share/nginx/html

# Limpiar archivos por defecto de Nginx
RUN rm -rf ./*

# Copiar los archivos estáticos construidos desde el Stage 1
# (Cambia 'dist' por 'build' o 'out' si usas otro framework diferente a Vite)
COPY --from=builder /app/dist .

# Copiar configuración personalizada de Nginx para manejar el enrutamiento SPA
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]